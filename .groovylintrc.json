{
  "extends": "recommended",
  "rules": {
    "UnnecessaryGetter": "off",
    "UnnecessaryGString": "off",
    "UnnecessaryReturnKeyword": "off",
    "UnnecessarySemicolon": "off",
    "UnnecessaryPackageReference": "off",
    "UnnecessaryDefInFieldDeclaration": "off",
    "UnnecessaryDefInMethodDeclaration": "off",
    "UnnecessaryDefInVariableDeclaration": "off",
    "UnnecessaryObjectReferences": "off",
    "UnnecessaryParenthesesForMethodCallWithClosure": "off",
    "UnnecessaryElseStatement": "off",
    "UnnecessarySetter": "off",
    "UnnecessarySelfAssignment": "off",

    "NoDef": "off",
    "MethodReturnTypeRequired": "off",
    "VariableTypeRequired": "off",
    "FieldTypeRequired": "off",
    "MethodParameterTypeRequired": "off",

    "CompileStatic": "off",
    "FactoryMethodName": "off",

    "ClassJavadoc": "off",
    "JavadocEmptyFirstLine": "off",
    "JavadocEmptyLastLine": "off",
    "JavadocConsecutiveEmptyLines": "off",

    "Indentation": "off",
    "LineLength": { "length": 200 },
    "ClassSize": "off",
    "MethodSize": "off",
    "AbcMetric": "off",
    "CyclomaticComplexity": "off",
    "CrapMetric": "off",
    "NestedBlockDepth": "off",
    "MethodCount": "off",
    "ParameterCount": "off",

    "DuplicateStringLiteral": "off",
    "DuplicateNumberLiteral": "off",
    "DuplicateMapLiteral": "off",
    "DuplicateListLiteral": "off",

    "ImplicitClosureParameter": "off",
    "ImplicitReturnStatement": "off",
    "PublicMethodsBeforeNonPublicMethods": "off",
    "StaticMethodsBeforeInstanceMethods": "off",
    "GetterMethodCouldBeProperty": "off",
    "FieldName": "off",
    "VariableName": "off",
    "MethodName": "off",
    "ParameterName": "off",

    "BracesForMethod": "off",
    "BracesForClass": "off",
    "BracesForIfElse": "off",
    "BracesForForLoop": "off",
    "BracesForTryCatchFinally": "off",
    "IfStatementBraces": "off",
    "ElseBlockBraces": "off",
    "IfStatementCouldBeTernary": "off",
    "InvertedIfElse": "off",
    "ConfusingTernary": "off",
    "CouldBeElvis": "off",
    "CouldBeSwitchStatement": "off",

    "SpaceAroundOperator": "off",
    "SpaceAfterComma": "off",
    "SpaceAfterOpeningBrace": "off",
    "SpaceBeforeClosingBrace": "off",
    "SpaceAfterIf": "off",
    "SpaceAfterFor": "off",
    "SpaceAfterWhile": "off",
    "SpaceAfterSwitch": "off",
    "SpaceAfterCatch": "off",
    "SpaceAfterSemicolon": "off",
    "SpaceAroundMapEntryColon": "off",
    "SpaceBeforeOpeningBrace": "off",
    "SpaceAfterClosingBrace": "off",
    "SpaceAfterMethodCallName": "off",
    "SpaceAfterMethodDeclarationName": "off",
    "SpaceAroundClosureArrow": "off",
    "SpaceInsideParentheses": "off",
    "ConsecutiveBlankLines": "off",
    "TrailingWhitespace": "off",
    "TrailingComma": "off",
    "BlockStartsWithBlankLine": "off",
    "BlockEndsWithBlankLine": "off",

    "GStringExpressionWithinString": "off",
    "ExplicitCallToEqualsMethod": "off",
    "ExplicitCallToCompareToMethod": "off",
    "ReturnNullFromCatchBlock": "off",
    "ReturnsNullInsteadOfEmptyCollection": "off",
    "ReturnsNullInsteadOfEmptyArray": "off",

    "Instanceof": "off",
    "CatchException": "off",
    "NoScriptBindings": "off",
    "NoJavaUtilDate": "off",
    "NoWildcardImports": "off",
    "SimpleDateFormatMissingLocale": "off",
    "InsecureRandom": "off"
  }
}
